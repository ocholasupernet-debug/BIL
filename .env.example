##############################################################
# OcholaSupernet — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
##############################################################

# ── API Server ────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ── Supabase (primary data store) ─────────────────────────
# REST API URL — format: https://xxx.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
# Anon (public) key — safe to expose in browser
VITE_SUPABASE_KEY=your-supabase-anon-key
# Service role key — bypasses RLS, server-side only, keep secret!
# SUPABASE_SERVICE_KEY=your-supabase-service-role-key  ← store as Replit Secret

# ── MikroTik Default Router ───────────────────────────────
# Used by GET /api/router/env/live (single "default" router).
# Multi-router setups store credentials per-router in Supabase isp_routers.
#
# ⚠ REMOTE CONNECTION REQUIREMENTS:
#   - MIKROTIK_HOST must be the router's PUBLIC IP (not 192.168.x.x)
#   - Port 8728 (plain API) or 8729 (API-SSL, preferred for internet)
#   - VPS IP must be allowed in the router firewall (download firewall script
#     from GET /api/router/:id/firewall-script?vpsIp=<your-vps-ip>)
#   - If behind NAT with no public IP, use VPN tunnel (see MIKROTIK_BRIDGE_IP)
#
MIKROTIK_HOST=your-router-public-ip-or-hostname

# IMPORTANT: store MIKROTIK_PASSWORD as a Secret, never commit it here.
# MIKROTIK_PASSWORD=your-router-api-password      ← store as Replit Secret

# OPTIONAL — defaults shown:
# MIKROTIK_USERNAME=admin         # API user on the router (not the web UI user)
# MIKROTIK_PORT=8728              # 8728 = plain, 8729 = API-SSL
# MIKROTIK_USE_SSL=false          # "true" to force encrypted API-SSL (port 8729)
# MIKROTIK_TLS_VERIFY=false       # "true" if router has a valid signed certificate

# ── VPN Tunnel Fallback ────────────────────────────────────
# If the router has no public IP, connect through a VPN tunnel.
# Set MIKROTIK_BRIDGE_IP to the IP the router gets inside the VPN.
# The backend will automatically try MIKROTIK_HOST first, then BRIDGE_IP.
# MIKROTIK_BRIDGE_IP=10.8.0.2    # VPN tunnel IP of the router (e.g., OpenVPN)

# ── Connection Tuning ──────────────────────────────────────
# MIKROTIK_CONNECT_TIMEOUT=15000  # ms to wait for TCP connect (default: 15000)
# MIKROTIK_REQUEST_TIMEOUT=20000  # ms to wait for API response (default: 20000)
# MIKROTIK_MAX_RETRIES=2          # how many times to retry failed connections

# ── Frontend ───────────────────────────────────────────────
# BASE_PATH should stay "/" for VPS root hosting
BASE_PATH=/
