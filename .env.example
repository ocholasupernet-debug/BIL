##############################################################
# OcholaSupernet — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
##############################################################

# ── API Server ────────────────────────────────────────────
# Port the Express API server listens on
PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ocholasupernet

# ── Frontend (only needed if building without nginx) ──────
# BASE_PATH should stay "/" for VPS root hosting
BASE_PATH=/

# ── Optional ─────────────────────────────────────────────
# Set to "production" on the VPS
NODE_ENV=production

# ── MikroTik Default Router ───────────────────────────────
# Used by GET /api/router/env/live for a single "default" router.
# Per-router credentials for multi-router setups are stored in the database.
#
# REQUIRED if using the env-based endpoint:
MIKROTIK_HOST=192.168.1.1
# IMPORTANT: store MIKROTIK_PASSWORD as a Secret, never commit it here.
# MIKROTIK_PASSWORD=your-router-api-password

# OPTIONAL — defaults shown:
# MIKROTIK_USERNAME=admin
# MIKROTIK_PORT=8728          # 8728 = plain, 8729 = SSL (API-SSL)
# MIKROTIK_USE_SSL=false      # set true to use encrypted API-SSL connection
# MIKROTIK_TLS_VERIFY=false   # set true if router has a valid TLS certificate
